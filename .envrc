source_up_if_exists
dotenv_if_exists .env

# Fetch secrets from Bitwarden Secrets Manager if not already set
if command -v bws &>/dev/null; then
  _BWS_CACHE=$(bws secret list --output json 2>/dev/null)
  _bws_secret() {
    echo "$_BWS_CACHE" | jq -r --arg name "$1" '.[] | select(.key == $name) | .value'
  }

  [ -z "${RADIO_FRANCE_API_TOKEN:-}" ] && export RADIO_FRANCE_API_TOKEN=$(_bws_secret radio-france-api-token)
  [ -z "${BOT_TELEGRAM_TOKEN:-}" ] && export BOT_TELEGRAM_TOKEN=$(_bws_secret fip-telegram-bot-token)

  unset _BWS_CACHE
  unset -f _bws_secret
fi
